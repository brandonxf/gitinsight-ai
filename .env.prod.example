# ============================================================
# GitInsight AI — entorno de PRODUCCIÓN (plantilla)
# Copia a .env.prod y rellena. NO lo subas al repo.
#   cp .env.prod.example .env.prod && nano .env.prod
# ============================================================

# --- General ---
ENV=production
LOG_LEVEL=INFO

# --- Dirección pública del sitio (la usa Caddy) ---
# Con dominio  => HTTPS automático (Let's Encrypt). Recomendado.
#   SITE_ADDRESS=gitinsight.tudominio.com
# Sin dominio  => solo HTTP por la IP pública de la VM:
#   SITE_ADDRESS=:80
# Gratis: crea un subdominio en https://www.duckdns.org y apúntalo a tu IP.
SITE_ADDRESS=gitinsight.ejemplo.duckdns.org

# --- Base de datos (PostgreSQL + pgvector) ---
POSTGRES_USER=gitinsight
# Genera uno fuerte:  openssl rand -base64 24
POSTGRES_PASSWORD=CAMBIA_ESTO_por_uno_fuerte
POSTGRES_DB=gitinsight
# Debe coincidir con el usuario/clave/host de arriba (host = nombre del servicio "db").
DATABASE_URL=postgresql+asyncpg://gitinsight:CAMBIA_ESTO_por_uno_fuerte@db:5432/gitinsight

# --- Redis (broker Celery + pub/sub) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- CORS: el origen público (mismo que SITE_ADDRESS, con esquema) ---
CORS_ORIGINS=https://gitinsight.ejemplo.duckdns.org

# ============================================================
# Capa de IA — Groq free tier (rápido, $0, sin GPU ni RAM extra)
# Crea una API key gratis en https://console.groq.com/keys
# ============================================================
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=gsk_CAMBIA_ESTO
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# --- Embeddings (locales, CPU, gratis) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# Acota RAM/CPU de onnxruntime en el servidor (1-2 recomendado).
EMBEDDING_THREADS=2

# --- Límites de clonado ---
CLONE_MAX_SIZE_MB=300
CLONE_MAX_FILES=20000
CLONE_TIMEOUT_SECONDS=120
REPOS_CACHE_DIR=/data/repos_cache
