# ============================================================
# GitInsight AI — variables de entorno (plantilla)
# Copia este archivo a .env y ajusta los valores.
# Por defecto: 100% gratuito, sin claves de pago obligatorias.
# ============================================================

# --- General ---
ENV=development
LOG_LEVEL=INFO

# --- Base de datos (PostgreSQL + pgvector) ---
POSTGRES_USER=gitinsight
POSTGRES_PASSWORD=gitinsight
POSTGRES_DB=gitinsight
POSTGRES_HOST=db
POSTGRES_PORT=5432
# URL usada por SQLAlchemy async (asyncpg)
DATABASE_URL=postgresql+asyncpg://gitinsight:gitinsight@db:5432/gitinsight

# --- Redis (broker Celery + cache + pub/sub) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- CORS (orígenes permitidos para el frontend) ---
CORS_ORIGINS=http://localhost:5173,http://localhost

# ============================================================
# Capa de IA (agnóstica del proveedor)
# Modo recomendado para 16 GB RAM + iGPU (CPU-only): HÍBRIDO
#   - Chat/síntesis: Groq free tier (rápido, $0)
#   - Respaldo offline: Ollama qwen2.5-coder:3b
#   - Embeddings: locales (FastEmbed), siempre gratis
# ============================================================

# Proveedor de chat: "ollama" (local) | "openai_compat" (Groq/Gemini/OpenRouter)
LLM_PROVIDER=ollama

# --- Opción A: Ollama local (offline, gratis) ---
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen2.5-coder:3b
LLM_API_KEY=

# Síntesis IA (Fase 2): desactiva con LLM_ENABLED=false para análisis sin IA.
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=240
LLM_MAX_RETRIES=2

# --- Opción B: Groq free tier (rápido, gratis con registro) ---
# Descomenta y rellena para usar Groq en lugar de Ollama:
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxx

# --- Embeddings (locales, CPU, gratis) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ============================================================
# Límites de clonado de repos (seguridad / anti-abuso)
# ============================================================
CLONE_MAX_SIZE_MB=500
CLONE_MAX_FILES=20000
CLONE_TIMEOUT_SECONDS=120
REPOS_CACHE_DIR=/data/repos_cache
